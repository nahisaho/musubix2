{
  "name": "@musubix2/musubi",
  "version": "0.1.0",
  "description": "MUSUBIX2 Musubi — Lightweight wrapper for core SDD operations",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": { ".": { "import": "./dist/index.js", "types": "./dist/index.d.ts" } },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist *.tsbuildinfo",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@musubix2/core": "*",
    "@musubix2/workflow-engine": "*",
    "@musubix2/policy": "*",
    "@musubix2/ontology-mcp": "*",
    "@musubix2/codegraph": "*",
    "@musubix2/security": "*",
    "@musubix2/knowledge": "*",
    "@musubix2/decisions": "*",
    "@musubix2/neural-search": "*",
    "@musubix2/dfg": "*",
    "@musubix2/agent-orchestrator": "*",
    "@musubix2/expert-delegation": "*",
    "@musubix2/skill-harness": "*",
    "@musubix2/skill-manager": "*"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "typescript": "^5.7.0",
    "vitest": "^3.1.0"
  },
  "license": "MIT"
}
