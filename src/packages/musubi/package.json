{
  "name": "musubix2",
  "version": "0.3.2",
  "description": "MUSUBIX2 — Specification Driven Development System",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "musubix": "./bin/musubix.mjs",
    "musubix2": "./bin/musubix.mjs"
  },
  "files": [
    "dist",
    "bin",
    ".github"
  ],
  "keywords": [
    "sdd",
    "specification-driven-development",
    "musubix",
    "ears",
    "traceability",
    "requirements",
    "design",
    "mcp"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nahisaho/musubix2.git",
    "directory": "src/packages/musubi"
  },
  "homepage": "https://github.com/nahisaho/musubix2#readme",
  "bugs": {
    "url": "https://github.com/nahisaho/musubix2/issues"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "author": "nahisaho",
  "scripts": {
    "build": "tsc -p tsconfig.json && node scripts/bundle.mjs",
    "clean": "rm -rf dist *.tsbuildinfo",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "node scripts/copy-github-assets.mjs",
    "postpublish": "node scripts/clean-github-assets.mjs"
  },
  "dependencies": {
    "typescript": "^5.7.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "esbuild": "^0.28.0",
    "typescript": "^5.7.0",
    "vitest": "^3.1.0"
  },
  "license": "MIT"
}
