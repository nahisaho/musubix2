{
  "name": "musubix2",
  "version": "0.1.0",
  "description": "MUSUBIX2 — Specification Driven Development System",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "musubix": "./bin/musubix.mjs",
    "musubix2": "./bin/musubix.mjs"
  },
  "files": [
    "dist",
    "bin"
  ],
  "keywords": [
    "sdd",
    "specification-driven-development",
    "musubix",
    "ears",
    "traceability",
    "requirements",
    "design",
    "mcp"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nahisaho/musubix2.git",
    "directory": "src/packages/musubi"
  },
  "homepage": "https://github.com/nahisaho/musubix2#readme",
  "bugs": {
    "url": "https://github.com/nahisaho/musubix2/issues"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "author": "nahisaho",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist *.tsbuildinfo",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@musubix2/core": "*",
    "@musubix2/workflow-engine": "*",
    "@musubix2/policy": "*",
    "@musubix2/ontology-mcp": "*",
    "@musubix2/codegraph": "*",
    "@musubix2/security": "*",
    "@musubix2/knowledge": "*",
    "@musubix2/decisions": "*",
    "@musubix2/neural-search": "*",
    "@musubix2/dfg": "*",
    "@musubix2/agent-orchestrator": "*",
    "@musubix2/expert-delegation": "*",
    "@musubix2/skill-harness": "*",
    "@musubix2/skill-manager": "*"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "typescript": "^5.7.0",
    "vitest": "^3.1.0"
  },
  "license": "MIT"
}
